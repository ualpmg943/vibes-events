---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Vibe Events - Sonido e Iluminación Premium" } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Vibe Events</title>
		<!-- Google Fonts: Outfit for a modern, sleek look -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-zinc-950 text-zinc-50 font-['Outfit'] antialiased min-h-screen flex flex-col">
		<slot />
	</body>
</html>
