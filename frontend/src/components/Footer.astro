---
const currentYear = new Date().getFullYear();
---

<footer class="bg-zinc-950 border-t border-white/5 py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h3 class="text-xl font-bold mb-4 tracking-tighter"><span class="text-gold-500">VIBE</span>EVENTS</h3>
      <p class="text-zinc-400 text-sm leading-relaxed max-w-sm">
        Empresa especializada en sonido profesional, iluminación DMX y DJs para bodas y eventos exclusivos. Dirigida por Javi Berenguel.
      </p>
    </div>
    
    <div>
      <h4 class="text-lg font-semibold mb-4 text-white">Navegación</h4>
      <ul class="space-y-2 text-sm text-zinc-400">
        <li><a href="/" class="hover:text-gold-500 transition-colors">Inicio</a></li>
        <li><a href="/dj" class="hover:text-gold-500 transition-colors">DJ (Javi Berenguel)</a></li>
        <li><a href="/reservas" class="hover:text-gold-500 transition-colors">Reservas</a></li>
        <li><a href="/contacto" class="hover:text-gold-500 transition-colors">Contacto</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-lg font-semibold mb-4 text-white">Redes Sociales</h4>
      <ul class="space-y-2 text-sm text-zinc-400">
        <li class="flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          info@vibeevents.com
        </li>
        <li class="pt-2 flex gap-3">
          <!-- Instagram -->
          <a href="https://www.instagram.com/javiberenguel_/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-zinc-900 border border-white/10 flex items-center justify-center hover:bg-gradient-to-tr hover:from-yellow-500 hover:via-pink-500 hover:to-purple-500 hover:text-white hover:border-transparent transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
          </a>
          <!-- YouTube -->
          <a href="https://www.youtube.com/@JaviBerenguelMUSIC/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-zinc-900 border border-white/10 flex items-center justify-center hover:bg-red-600 hover:text-white hover:border-transparent transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
          <!-- TikTok -->
          <a href="https://www.tiktok.com/@javiberenguel_?lang=es-419" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-zinc-900 border border-white/10 flex items-center justify-center hover:bg-black hover:text-white hover:border-white/50 transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-white/5 text-center text-zinc-500 text-sm">
    &copy; {currentYear} VIBE EVENTS. Todos los derechos reservados.
  </div>
</footer>
