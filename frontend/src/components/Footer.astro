---
const currentYear = new Date().getFullYear();
---

<footer class="bg-zinc-950 border-t border-white/5 py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h3 class="text-xl font-bold mb-4"><span class="text-gold-500">Javi</span>Berenguel</h3>
      <p class="text-zinc-400 text-sm leading-relaxed max-w-sm">
        Servicios premium de DJ, sonido profesional e iluminación espectacular para que tu evento sea inolvidable.
      </p>
    </div>
    
    <div>
      <h4 class="text-lg font-semibold mb-4 text-white">Enlaces Rápidos</h4>
      <ul class="space-y-2 text-sm text-zinc-400">
        <li><a href="/#about" class="hover:text-gold-500 transition-colors">Biografía y Estilo</a></li>
        <li><a href="/#services" class="hover:text-gold-500 transition-colors">Servicios Disponibles</a></li>
        <li><a href="/reservas" class="hover:text-gold-500 transition-colors">Comprobar Disponibilidad</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-lg font-semibold mb-4 text-white">Contacto</h4>
      <ul class="space-y-2 text-sm text-zinc-400">
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          info@javiberenguel.com
        </li>
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
          +34 600 000 000
        </li>
        <li class="pt-4 flex gap-3">
          <!-- Redes Sociales Placeholder -->
          <a href="#" class="w-10 h-10 rounded-full bg-zinc-900 border border-white/10 flex items-center justify-center hover:bg-gold-500 hover:text-black hover:border-gold-500 transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-zinc-900 border border-white/10 flex items-center justify-center hover:bg-gold-500 hover:text-black hover:border-gold-500 transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-white/5 text-center text-zinc-500 text-sm">
    &copy; {currentYear} Javi Berenguel. Diseño premium por Pablo.
  </div>
</footer>
