---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'DJ', href: '/dj' },
  { label: 'Reservas', href: '/reservas' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-500 border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold tracking-tighter text-white flex items-center gap-1 hover:opacity-80 transition-opacity">
      <span class="text-gold-500">VIBE</span>EVENTS
    </a>

    <nav class="hidden md:flex gap-8">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-sm font-medium text-zinc-300 hover:text-gold-500 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button class="md:hidden text-zinc-300 hover:text-white" aria-label="Abrir menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');

  const updateHeader = () => {
    if (window.scrollY > 20) {
      header?.classList.remove('border-transparent');
      header?.classList.add('bg-zinc-950/60', 'backdrop-blur-xl', 'border-white/5');
    } else {
      header?.classList.add('border-transparent');
      header?.classList.remove('bg-zinc-950/60', 'backdrop-blur-xl', 'border-white/5');
    }
  };

  // Ejecutar al cargar por si ya tiene scroll
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
