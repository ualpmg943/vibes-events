---
// Componente de pasarela de pago / flujo de reserva
---

<div id="booking-flow-view" class="hidden max-w-5xl mx-auto transition-all duration-500">
  
  <div class="mb-8 flex items-center justify-between">
    <button id="back-to-packs-btn" class="flex items-center gap-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver a los packs
    </button>
    <div class="flex items-center gap-2 text-sm font-medium">
      <span class="text-gold-500">Paso <span id="current-step-display">1</span> de 3</span>
    </div>
  </div>

  <div class="rounded-[2.5rem] bg-zinc-900/50 border border-white/5 backdrop-blur-xl shadow-2xl p-8 md:p-12 relative overflow-hidden">
    <!-- Glow interior -->
    <div class="absolute -top-24 -right-24 w-72 h-72 bg-gold-500/5 rounded-full blur-[90px] pointer-events-none"></div>

    <form id="booking-form" action="https://formspree.io/f/xaqvbjlj" method="POST">
      <!-- Datos ocultos que se llenan con JS -->
      <input type="hidden" name="pack_seleccionado" id="input-pack" value="" />
      <input type="hidden" name="fecha_seleccionada" id="input-date" value="" />
      <input type="hidden" name="extras_seleccionados" id="input-extras" value="" />

      <!-- PASO 1: CALENDARIO -->
      <div id="step-1" class="step-container">
        <h2 class="text-2xl font-bold text-white mb-2">Selecciona la fecha</h2>
        <p class="text-zinc-500 text-sm mb-8">Elige el día de tu evento. Los días en gris no están disponibles.</p>
        
        <div class="max-w-md mx-auto bg-zinc-950/50 border border-white/5 rounded-3xl p-6 shadow-inner">
          <div class="flex justify-between items-center mb-6">
            <button type="button" class="p-2 text-zinc-400 hover:text-white"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg></button>
            <h3 class="font-bold text-white tracking-wide" id="calendar-month">Octubre 2026</h3>
            <button type="button" class="p-2 text-zinc-400 hover:text-white"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></button>
          </div>
          
          <div class="grid grid-cols-7 gap-2 mb-2 text-center text-[10px] font-bold text-zinc-600 uppercase tracking-widest">
            <div>Lu</div><div>Ma</div><div>Mi</div><div>Ju</div><div>Vi</div><div>Sá</div><div>Do</div>
          </div>
          
          <!-- Días del calendario generados por JS estáticamente para la demo -->
          <div class="grid grid-cols-7 gap-2 text-center text-sm" id="calendar-days">
            <!-- Rellenado por JS -->
          </div>
        </div>

        <div class="mt-10 flex justify-end">
          <button type="button" id="btn-next-1" disabled class="px-8 py-3 rounded-full bg-gold-500 text-black font-bold text-sm uppercase tracking-widest hover:bg-gold-400 transition-all shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
            Continuar
          </button>
        </div>
      </div>

      <!-- PASO 2: EXTRAS -->
      <div id="step-2" class="step-container hidden">
        <h2 class="text-2xl font-bold text-white mb-2">Añade extras</h2>
        <p class="text-zinc-500 text-sm mb-8">Mejora tu pack con estos servicios adicionales.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Extra 1 -->
          <label class="cursor-pointer group">
            <input type="checkbox" class="peer sr-only" value="Horas Extra" data-price="100€/h" />
            <div class="p-6 rounded-2xl border border-white/5 bg-zinc-950/50 peer-checked:border-gold-500/50 peer-checked:bg-gold-500/10 transition-all hover:bg-zinc-900 flex items-start gap-4">
              <div class="w-6 h-6 rounded border border-zinc-600 peer-checked:border-gold-500 peer-checked:bg-gold-500 flex items-center justify-center text-black shrink-0 mt-0.5 transition-colors">
                <svg class="opacity-0 peer-checked:opacity-100 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Horas Extra de DJ</h4>
                <p class="text-zinc-500 text-xs leading-relaxed mb-2">Alarga la fiesta el tiempo que necesites.</p>
                <span class="text-gold-400 text-xs font-semibold">+100€ / hora</span>
              </div>
            </div>
          </label>

          <!-- Extra 2 -->
          <label class="cursor-pointer group">
            <input type="checkbox" class="peer sr-only" value="Iluminación Premium" data-price="150€" />
            <div class="p-6 rounded-2xl border border-white/5 bg-zinc-950/50 peer-checked:border-gold-500/50 peer-checked:bg-gold-500/10 transition-all hover:bg-zinc-900 flex items-start gap-4">
              <div class="w-6 h-6 rounded border border-zinc-600 peer-checked:border-gold-500 peer-checked:bg-gold-500 flex items-center justify-center text-black shrink-0 mt-0.5 transition-colors">
                <svg class="opacity-0 peer-checked:opacity-100 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Iluminación Premium</h4>
                <p class="text-zinc-500 text-xs leading-relaxed mb-2">Cabezas móviles y láseres para un efecto WOW.</p>
                <span class="text-gold-400 text-xs font-semibold">+150€</span>
              </div>
            </div>
          </label>
          
          <!-- Extra 3 -->
          <label class="cursor-pointer group">
            <input type="checkbox" class="peer sr-only" value="Fuego Frío" data-price="90€" />
            <div class="p-6 rounded-2xl border border-white/5 bg-zinc-950/50 peer-checked:border-gold-500/50 peer-checked:bg-gold-500/10 transition-all hover:bg-zinc-900 flex items-start gap-4">
              <div class="w-6 h-6 rounded border border-zinc-600 peer-checked:border-gold-500 peer-checked:bg-gold-500 flex items-center justify-center text-black shrink-0 mt-0.5 transition-colors">
                <svg class="opacity-0 peer-checked:opacity-100 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Máquinas de Fuego Frío</h4>
                <p class="text-zinc-500 text-xs leading-relaxed mb-2">Ideal para el baile nupcial o momentos clave.</p>
                <span class="text-gold-400 text-xs font-semibold">+90€</span>
              </div>
            </div>
          </label>
        </div>

        <div class="mt-10 flex justify-between">
          <button type="button" id="btn-prev-2" class="px-8 py-3 rounded-full border border-white/10 text-white font-bold text-sm uppercase tracking-widest hover:bg-white/5 transition-colors">
            Atrás
          </button>
          <button type="button" id="btn-next-2" class="px-8 py-3 rounded-full bg-gold-500 text-black font-bold text-sm uppercase tracking-widest hover:bg-gold-400 transition-all shadow-lg">
            Siguiente
          </button>
        </div>
      </div>

      <!-- PASO 3: RESUMEN Y DATOS -->
      <div id="step-3" class="step-container hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          
          <div>
            <h2 class="text-2xl font-bold text-white mb-2">Tus datos</h2>
            <p class="text-zinc-500 text-sm mb-8">Completa el formulario para enviar tu solicitud de reserva.</p>
            
            <div class="flex flex-col gap-5">
              <div>
                <label class="block text-[10px] font-bold text-gold-500/70 uppercase tracking-[0.2em] mb-2">Nombre completo</label>
                <input type="text" name="name" required class="w-full bg-zinc-950/70 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm placeholder:text-zinc-700 focus:outline-none focus:border-gold-500/60 focus:ring-1 focus:ring-gold-500/30 transition-all" placeholder="Ej. Pablo García" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gold-500/70 uppercase tracking-[0.2em] mb-2">Email</label>
                <input type="email" name="email" required class="w-full bg-zinc-950/70 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm placeholder:text-zinc-700 focus:outline-none focus:border-gold-500/60 focus:ring-1 focus:ring-gold-500/30 transition-all" placeholder="correo@ejemplo.com" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gold-500/70 uppercase tracking-[0.2em] mb-2">Teléfono</label>
                <input type="tel" name="phone" required class="w-full bg-zinc-950/70 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm placeholder:text-zinc-700 focus:outline-none focus:border-gold-500/60 focus:ring-1 focus:ring-gold-500/30 transition-all" placeholder="+34 600 000 000" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gold-500/70 uppercase tracking-[0.2em] mb-2">Lugar del evento (Localidad/Finca)</label>
                <input type="text" name="location" class="w-full bg-zinc-950/70 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm placeholder:text-zinc-700 focus:outline-none focus:border-gold-500/60 focus:ring-1 focus:ring-gold-500/30 transition-all" placeholder="Ej. Finca el Recreo, Almería" />
              </div>
            </div>
          </div>

          <div class="bg-zinc-950/50 border border-white/5 rounded-3xl p-8 flex flex-col">
            <h3 class="text-[10px] font-bold text-gold-500/70 uppercase tracking-[0.2em] mb-6">Resumen de la reserva</h3>
            
            <div class="flex-grow space-y-6">
              <div class="flex justify-between items-start border-b border-white/5 pb-4">
                <div>
                  <p class="text-xs text-zinc-500 mb-1">Pack</p>
                  <p id="summary-pack-name" class="text-white font-bold text-lg">-</p>
                </div>
              </div>
              
              <div class="flex justify-between items-start border-b border-white/5 pb-4">
                <div>
                  <p class="text-xs text-zinc-500 mb-1">Fecha</p>
                  <p id="summary-date" class="text-white font-bold text-lg">-</p>
                </div>
              </div>

              <div>
                <p class="text-xs text-zinc-500 mb-2">Extras seleccionados</p>
                <ul id="summary-extras-list" class="space-y-2">
                  <li class="text-sm text-zinc-400">Ninguno</li>
                </ul>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-white/10">
              <p id="form-feedback" class="text-sm mb-4 font-medium transition-colors"></p>
              <div class="flex justify-between items-center gap-4">
                <button type="button" id="btn-prev-3" class="px-6 py-3 rounded-full border border-white/10 text-white font-bold text-sm uppercase tracking-widest hover:bg-white/5 transition-colors">
                  Atrás
                </button>
                <button type="submit" id="submit-booking-btn" class="flex-grow py-3 rounded-full bg-gold-500 text-black font-bold text-sm uppercase tracking-widest hover:bg-gold-400 transition-all shadow-[0_0_20px_rgba(212,175,55,0.3)] hover:shadow-[0_0_30px_rgba(212,175,55,0.5)]">
                  Solicitar Reserva
                </button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </form>
  </div>
</div>

<script>
  // Script para manejar el flujo de la pasarela y el calendario
  document.addEventListener('DOMContentLoaded', () => {
    // Referencias DOM
    const packView = document.getElementById('pack-selection-view');
    const flowView = document.getElementById('booking-flow-view');
    const selectPackBtns = document.querySelectorAll('.select-pack-btn');
    const backToPacksBtn = document.getElementById('back-to-packs-btn');
    
    const steps = [
      document.getElementById('step-1'),
      document.getElementById('step-2'),
      document.getElementById('step-3')
    ];
    const stepDisplay = document.getElementById('current-step-display');
    
    // Inputs ocultos
    const inputPack = document.getElementById('input-pack') as HTMLInputElement;
    const inputDate = document.getElementById('input-date') as HTMLInputElement;
    const inputExtras = document.getElementById('input-extras') as HTMLInputElement;
    
    // Elementos del resumen
    const summaryPack = document.getElementById('summary-pack-name');
    const summaryDate = document.getElementById('summary-date');
    const summaryExtras = document.getElementById('summary-extras-list');
    
    // Botones de navegación
    const btnNext1 = document.getElementById('btn-next-1') as HTMLButtonElement;
    const btnNext2 = document.getElementById('btn-next-2');
    const btnPrev2 = document.getElementById('btn-prev-2');
    const btnPrev3 = document.getElementById('btn-prev-3');
    
    // Formulario
    const form = document.getElementById('booking-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-booking-btn') as HTMLButtonElement;
    const formFeedback = document.getElementById('form-feedback');

    let currentStep = 0;
    
    // Calendario Logic
    const calendarDays = document.getElementById('calendar-days');
    let selectedDate = null;
    
    // Generar calendario de prueba (Mes actual ficticio con días deshabilitados)
    function renderCalendar() {
      if (!calendarDays) return;
      calendarDays.innerHTML = '';
      
      const totalDays = 31;
      const firstDayOffset = 3; // Empieza en Jueves por ejemplo
      
      // Espacios vacíos iniciales
      for(let i=0; i<firstDayOffset; i++) {
        const empty = document.createElement('div');
        calendarDays.appendChild(empty);
      }
      
      // Días
      for(let i=1; i<=totalDays; i++) {
        const dayBtn = document.createElement('button');
        dayBtn.type = 'button';
        
        // Simular días ocupados (fines de semana al azar, ej: 10, 11, 17, 24)
        const isUnavailable = [10, 11, 17, 24].includes(i);
        
        if (isUnavailable) {
          dayBtn.className = 'aspect-square flex items-center justify-center rounded-full text-zinc-600 line-through cursor-not-allowed text-xs';
          dayBtn.disabled = true;
        } else {
          dayBtn.className = 'day-btn aspect-square flex items-center justify-center rounded-full text-white hover:bg-white/10 transition-colors text-sm font-medium';
        }
        
        dayBtn.textContent = i.toString();
        
        if (!isUnavailable) {
          dayBtn.addEventListener('click', () => {
            // Deseleccionar anterior
            document.querySelectorAll('.day-btn').forEach(btn => {
              btn.classList.remove('bg-gold-500', 'text-black');
              btn.classList.add('text-white', 'hover:bg-white/10');
            });
            // Seleccionar nuevo
            dayBtn.classList.remove('text-white', 'hover:bg-white/10');
            dayBtn.classList.add('bg-gold-500', 'text-black');
            
            selectedDate = `${i} Octubre 2026`;
            inputDate.value = selectedDate;
            if(summaryDate) summaryDate.textContent = selectedDate;
            
            if(btnNext1) btnNext1.disabled = false;
          });
        }
        calendarDays.appendChild(dayBtn);
      }
    }
    
    renderCalendar();

    // Navegación de vistas (Packs -> Flow)
    selectPackBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const packName = target.getAttribute('data-pack-name') || '';
        
        // Guardar pack
        if(inputPack) inputPack.value = packName;
        if(summaryPack) summaryPack.textContent = packName;
        
        // Cambiar vista
        if(packView && flowView) {
          packView.classList.add('hidden');
          flowView.classList.remove('hidden');
        }
        goToStep(0);
      });
    });

    if(backToPacksBtn) {
      backToPacksBtn.addEventListener('click', () => {
        if(packView && flowView) {
          flowView.classList.add('hidden');
          packView.classList.remove('hidden');
        }
      });
    }

    // Funciones de pasos
    function goToStep(index) {
      steps.forEach((step, i) => {
        if(step) {
          if (i === index) {
            step.classList.remove('hidden');
            // Animación suave
            step.style.opacity = '0';
            setTimeout(() => step.style.opacity = '1', 50);
          } else {
            step.classList.add('hidden');
          }
        }
      });
      currentStep = index;
      if(stepDisplay) stepDisplay.textContent = (index + 1).toString();
      
      // Actualizar resumen si entramos al paso 3
      if (index === 2) updateExtrasSummary();
    }

    if(btnNext1) btnNext1.addEventListener('click', () => goToStep(1));
    if(btnNext2) btnNext2.addEventListener('click', () => goToStep(2));
    if(btnPrev2) btnPrev2.addEventListener('click', () => goToStep(0));
    if(btnPrev3) btnPrev3.addEventListener('click', () => goToStep(1));

    // Extras lógicas
    function updateExtrasSummary() {
      const checkboxes = document.querySelectorAll('#step-2 input[type="checkbox"]:checked') as NodeListOf<HTMLInputElement>;
      const extras = Array.from(checkboxes).map(cb => `${cb.value} (${cb.getAttribute('data-price')})`);
      
      if(inputExtras) inputExtras.value = extras.join(', ');
      
      if(summaryExtras) {
        if (extras.length === 0) {
          summaryExtras.innerHTML = '<li class="text-sm text-zinc-400">Ninguno</li>';
        } else {
          summaryExtras.innerHTML = extras.map(ex => `<li class="text-sm text-white flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-gold-500"></div>${ex}</li>`).join('');
        }
      }
    }

    // Form Submission (AJAX Formspree)
    if (form && submitBtn && formFeedback) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = "Enviando...";

        try {
          const response = await fetch(form.action, {
            method: form.method,
            body: formData,
            headers: {
              Accept: "application/json",
            },
          });

          if (response.ok) {
            formFeedback.textContent = "¡Reserva solicitada con éxito! Te contactaremos pronto.";
            formFeedback.className = "text-sm mb-4 font-medium text-green-500";
            form.reset();
            // Deseleccionar fecha y resetear
            document.querySelectorAll('.day-btn').forEach(b => {
              b.classList.remove('bg-gold-500', 'text-black');
              b.classList.add('text-white');
            });
            selectedDate = null;
            if(btnNext1) btnNext1.disabled = true;
            
            setTimeout(() => {
              if(packView && flowView) {
                flowView.classList.add('hidden');
                packView.classList.remove('hidden');
              }
              formFeedback.textContent = "";
            }, 3000);

          } else {
            formFeedback.textContent = "Hubo un error al enviar la solicitud.";
            formFeedback.className = "text-sm mb-4 font-medium text-red-500";
          }
        } catch (error) {
          formFeedback.textContent = "Error de conexión. Inténtalo más tarde.";
          formFeedback.className = "text-sm mb-4 font-medium text-red-500";
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      });
    }
  });
</script>
