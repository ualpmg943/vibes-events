---
// Componente de selección de extras para la reserva
interface Extra {
  id: string;
  name: string;
  description: string;
  price: string;
  icon: string;
}

const extras: Extra[] = [
  {
    id: "extra-horas",
    name: "Horas Extra",
    description: "Alarga la fiesta el tiempo que necesites.",
    price: "+100€ / hora",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    id: "extra-luz",
    name: "Iluminación Premium",
    description: "Cabezas móviles, estrobos y láseres para un efecto espectacular.",
    price: "+150€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L8.5 8.5H2l5.5 5.5-2 7.5L12 17.5l6.5 4L16.5 14 22 8.5h-6.5z"/></svg>`
  },
  {
    id: "extra-fuego",
    name: "Fuego Frío",
    description: "Ideal para el baile nupcial o el momento más especial.",
    price: "+90€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`
  },
  {
    id: "extra-photobooth",
    name: "Photo Booth",
    description: "Cabina de fotos con props y impresión instantánea.",
    price: "+200€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`
  },
  {
    id: "extra-streaming",
    name: "Streaming en Directo",
    description: "Retransmisión del evento en YouTube o Instagram Live.",
    price: "+120€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  {
    id: "extra-confeti",
    name: "Cañón de Confeti",
    description: "Un impacto visual explosivo para el momento más memorable.",
    price: "+60€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`
  }
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4" id="extras-grid">
  {extras.map((extra) => (
    <label for={extra.id} class="cursor-pointer group block">
      <input 
        type="checkbox" 
        id={extra.id}
        class="peer sr-only extra-checkbox" 
        value={extra.name}
        data-price={extra.price}
      />
      <div class="h-full p-5 rounded-2xl border border-white/5 bg-zinc-900/40 peer-checked:border-gold-500/50 peer-checked:bg-gold-500/8 peer-checked:shadow-[0_0_20px_rgba(212,175,55,0.1)] transition-all duration-300 hover:border-white/15 hover:bg-zinc-900/60 flex flex-col gap-3">
        
        <!-- Header del extra -->
        <div class="flex items-start justify-between gap-3">
          <div class="w-9 h-9 rounded-xl bg-zinc-950 border border-white/8 flex items-center justify-center text-zinc-500 peer-checked:text-gold-500 group-has-[:checked]:text-gold-500 transition-colors shrink-0" set:html={extra.icon} />
          
          <!-- Custom checkbox visual -->
          <div class="w-5 h-5 rounded-md border-2 border-zinc-700 peer-checked:border-gold-500 peer-checked:bg-gold-500 group-has-[:checked]:border-gold-500 group-has-[:checked]:bg-gold-500 flex items-center justify-center transition-all shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-black opacity-0 group-has-[:checked]:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        </div>

        <div>
          <p class="text-white font-semibold text-sm mb-1">{extra.name}</p>
          <p class="text-zinc-500 text-xs leading-relaxed">{extra.description}</p>
        </div>
        
        <p class="text-gold-400 text-xs font-bold mt-auto pt-2 border-t border-white/5">{extra.price}</p>
      </div>
    </label>
  ))}
</div>
