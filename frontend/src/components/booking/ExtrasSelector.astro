---
// Componente de selección de extras para la reserva con soporte para múltiples unidades
interface Extra {
  id: string;
  name: string;
  description: string;
  price: string;
  icon: string;
}

const extras: Extra[] = [
  {
    id: "dj-extra",
    name: "Servicio de DJ Adicional",
    description: "Amplía la sesión de música con nuestro DJ profesional (precio por hora).",
    price: "+80€ / hora",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    id: "shisha-2",
    name: "Pack Shishas Premium (2 unidades)",
    description: "Cachimbas de alta gama con variedad de sabores y carbón ilimitado.",
    price: "+50€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4a2 2 0 1 0-1.4-3.4H2"/><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/></svg>`
  },
  {
    id: "shisha-4",
    name: "Pack Shishas Premium (4 unidades)",
    description: "Cachimbas de alta gama con variedad de sabores y carbón ilimitado.",
    price: "+90€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4a2 2 0 1 0-1.4-3.4H2"/><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/></svg>`
  },
  {
    id: "violin",
    name: "Actuación de Violinista en Vivo",
    description: "Show elegante y dinámico de violín eléctrico para momentos clave.",
    price: "+150€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
  },
  {
    id: "animacion",
    name: "Show de Animación y Performance",
    description: "Animadores profesionales para elevar la energía de la fiesta.",
    price: "+120€",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="extras-grid">
  {extras.map((extra) => (
    <div 
      class="extra-card group relative h-full p-5 rounded-2xl border border-white/5 bg-zinc-900/40 transition-all duration-300 hover:border-white/15 hover:bg-zinc-900/60 flex flex-col gap-3"
      data-id={extra.id}
      data-name={extra.name}
      data-price={extra.price}
    >
      <!-- Input oculto para el valor -->
      <input type="hidden" class="extra-qty-input" id={`input-${extra.id}`} value="0" />
      
      <!-- Header del extra -->
      <div class="flex items-start justify-between gap-3">
        <div class="w-9 h-9 rounded-xl bg-zinc-950 border border-white/8 flex items-center justify-center text-zinc-500 group-[.active]:text-gold-500 transition-colors shrink-0" set:html={extra.icon} />
        
        <!-- Badge de cantidad si > 0 -->
        <div class="qty-badge hidden group-[.active]:flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full bg-gold-500 text-black text-[10px] font-bold">
          x<span class="qty-badge-val">0</span>
        </div>
      </div>

      <div>
        <p class="text-white font-semibold text-sm mb-1">{extra.name}</p>
        <p class="text-zinc-500 text-xs leading-relaxed line-clamp-2">{extra.description}</p>
      </div>
      
      <div class="flex items-center justify-between mt-auto pt-3 border-t border-white/5">
        <p class="text-gold-400 text-xs font-bold">{extra.price}</p>
        
        <!-- Selector de cantidad -->
        <div class="flex items-center gap-1 bg-zinc-950 p-1 rounded-xl border border-white/5">
          <button type="button" class="qty-minus w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/5 text-zinc-500 transition-colors disabled:opacity-20" data-id={extra.id}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <span class="qty-display text-white font-bold text-xs min-w-[18px] text-center" data-id={extra.id}>0</span>
          <button type="button" class="qty-plus w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/5 text-zinc-500 transition-colors" data-id={extra.id}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .extra-card.active {
    border-color: rgba(212, 175, 55, 0.5);
    background-color: rgba(212, 175, 55, 0.08);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.1);
  }
  
  .qty-minus:not(:disabled):hover, .qty-plus:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .extra-card.active .qty-display {
    color: #d4af37;
  }
</style>
