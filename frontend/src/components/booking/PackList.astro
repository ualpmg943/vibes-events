---
// Componente para listar los packs de reserva disponibles
const packs = [
  {
    id: "pack-basico",
    name: "Pack Básico",
    price: "Desde 350€",
    description: "Ideal para fiestas privadas, cumpleaños o eventos de tamaño reducido.",
    features: ["4 horas de DJ Set", "Equipo de sonido profesional (hasta 100 pax)", "Iluminación básica", "Reunión previa de planificación"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>`
  },
  {
    id: "pack-premium",
    name: "Pack Premium",
    price: "Desde 650€",
    description: "La experiencia completa para bodas o eventos corporativos con alta exigencia.",
    features: ["Hasta 8 horas de DJ Set", "Equipo de sonido line array (hasta 300 pax)", "Puente de luces y cabina iluminada", "Máquina de humo/fuego frío", "Asesoramiento musical completo"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`,
    popular: true
  },
  {
    id: "pack-club",
    name: "Club / Festival",
    price: "Consultar",
    description: "Sets exclusivos de música comercial, electrónica o urbana para salas y festivales.",
    features: ["Sesión de 2 a 4 horas", "Rider técnico específico", "Promoción en redes sociales", "Visuales personalizadas"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg>`
  }
];
---

<div id="pack-selection-view" class="max-w-7xl mx-auto transition-all duration-500">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {packs.map((pack) => (
      <div 
        class={`relative p-8 rounded-[2rem] bg-zinc-900/50 border backdrop-blur-xl shadow-2xl flex flex-col group hover:-translate-y-2 transition-all duration-300 ${pack.popular ? 'border-gold-500/40 shadow-[0_0_30px_rgba(212,175,55,0.15)]' : 'border-white/5'}`}
      >
        {pack.popular && (
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gold-500 text-black text-[10px] font-bold uppercase tracking-widest py-1.5 px-4 rounded-full shadow-lg">
            Más solicitado
          </div>
        )}
        
        <div class="w-14 h-14 rounded-2xl bg-zinc-950 border border-white/10 flex items-center justify-center text-gold-500 mb-6 group-hover:scale-110 transition-transform shadow-inner" set:html={pack.icon} />
        
        <h3 class="text-2xl font-bold text-white mb-2">{pack.name}</h3>
        <p class="text-gold-400 font-semibold mb-4">{pack.price}</p>
        <p class="text-zinc-400 text-sm mb-8 leading-relaxed flex-grow">{pack.description}</p>
        
        <ul class="flex flex-col gap-3 mb-8">
          {pack.features.map(feature => (
            <li class="flex items-start gap-3 text-sm text-zinc-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>

        <button 
          data-pack-id={pack.id}
          data-pack-name={pack.name}
          class="select-pack-btn w-full py-4 rounded-full bg-zinc-100 text-black font-bold text-sm uppercase tracking-widest hover:bg-gold-500 transition-colors shadow-lg active:scale-95 mt-auto"
        >
          Seleccionar Pack
        </button>
      </div>
    ))}
  </div>
</div>
