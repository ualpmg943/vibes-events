---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RecentMoments from "../components/dj/RecentMoments.astro";
import PartyBrands from "../components/dj/PartyBrands.astro";
---

<Layout
  title="DJ Javi Berenguel"
  description="Javi Berenguel - DJ y fundador de VIBE EVENTS, promotor de Gamberro Party y La Juerga."
>
  <Header />

  <main class="flex-grow pt-20">
    <!-- Perfil del DJ -->
    <section class="relative py-24 overflow-hidden border-b border-white/5">
      <!-- Fondo Glow -->
      <div class="absolute inset-0 z-0 pointer-events-none flex justify-center">
        <div
          class="w-[800px] h-[600px] bg-gold-500/10 rounded-full blur-[150px] -translate-y-1/4"
        >
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <!-- Columna Izquierda: Identidad -->
          <div class="lg:col-span-5 flex flex-col gap-8">
            <div
              class="p-8 rounded-[2rem] bg-zinc-900/40 border border-white/5 backdrop-blur-xl shadow-2xl relative overflow-hidden group"
            >
              <!-- Brillo sutil de fondo de la tarjeta -->
              <div
                class="absolute -top-20 -right-20 w-40 h-40 bg-gold-500/20 rounded-full blur-3xl group-hover:bg-gold-500/30 transition-colors"
              >
              </div>

              <div class="flex items-center gap-6 mb-8">
                <!-- Avatar DJ Circular -->
                <div class="relative w-28 h-28 shrink-0">
                  <div
                    class="absolute inset-0 bg-gold-500 rounded-full animate-pulse blur-md opacity-30 group-hover:opacity-60 transition-opacity"
                  >
                  </div>
                  <img
                    src="/javi-dj.jpg"
                    alt="Javi Berenguel"
                    class="relative z-10 w-full h-full object-cover rounded-full border border-white/10 shadow-xl ring-4 ring-zinc-950"
                  />
                </div>
                <div>
                  <h1 class="text-3xl font-bold tracking-tight text-white mb-2">
                    Javi <span
                      class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600"
                      >Berenguel</span
                    >
                  </h1>
                </div>
              </div>

              <p class="text-zinc-400 text-sm leading-relaxed mb-8">
                Fundador de VIBE EVENTS y mente creativa detrás de los conceptos
                de fiesta más potentes del sur.
              </p>

              <!-- Redes del DJ -->
              <div class="flex items-center gap-3">
                <a
                  href="https://www.instagram.com/javiberenguel_/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-zinc-950/50 border border-white/5 flex items-center justify-center hover:bg-gradient-to-tr hover:from-yellow-500 hover:via-pink-500 hover:to-purple-500 hover:text-white hover:border-transparent transition-all shadow-inner group-social"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-zinc-400 transition-colors"
                    ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                    ></rect><path
                      d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                    ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                    ></line></svg
                  >
                </a>
                <a
                  href="https://www.youtube.com/@JaviBerenguelMUSIC/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-zinc-950/50 border border-white/5 flex items-center justify-center hover:bg-red-600 hover:text-white hover:border-transparent transition-all shadow-inner group-social"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-zinc-400 transition-colors"
                    ><path
                      d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"
                    ></path><polygon
                      points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
                    ></polygon></svg
                  >
                </a>
                <a
                  href="https://www.tiktok.com/@javiberenguel_?lang=es-419"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-zinc-950/50 border border-white/5 flex items-center justify-center hover:bg-white hover:text-black hover:border-transparent transition-all shadow-inner group-social"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-zinc-400 transition-colors"
                    ><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg
                  >
                </a>
              </div>

              <!-- Booking & Management -->
              <div class="mt-8 pt-8 border-t border-white/5">
                <p
                  class="text-[10px] font-bold text-gold-500/50 uppercase tracking-[0.2em] mb-4"
                >
                  Management & Booking
                </p>
                <div class="flex items-center gap-4 group/booking">
                  <div
                    class="w-10 h-10 rounded-full bg-zinc-950 border border-white/5 flex items-center justify-center text-zinc-500 group-hover/booking:text-gold-500 transition-colors shadow-inner"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                      ></path></svg
                    >
                  </div>
                  <div>
                    <p class="text-white font-medium text-sm">Yordan</p>
                    <a
                      href="tel:+34000000000"
                      class="text-zinc-500 text-xs hover:text-gold-400 transition-colors tracking-wider"
                      >+34 618 64 50 43</a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Información -->
          <div class="lg:col-span-7 flex flex-col gap-6">
            <div
              class="p-8 rounded-[2rem] bg-zinc-900/40 border border-white/5 backdrop-blur-xl shadow-xl flex flex-col sm:flex-row gap-6 hover:bg-zinc-900/60 transition-colors"
            >
              <div
                class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0 border border-gold-500/20 shadow-inner"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-gold-500"
                  ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
                  ></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path
                    d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg
                >
              </div>
              <div>
                <h2 class="text-xl font-semibold text-white mb-3">
                  Versatilidad Musical
                </h2>
                <p class="text-zinc-400 text-sm leading-relaxed">
                  Especializado en música comercial, reguetón, música urbana y
                  electrónica. Adapto mi set a la pista de baile en tiempo real,
                  observando al público para asegurar que la energía no baje y
                  nadie se quede sentado.
                </p>
              </div>
            </div>

            <div
              class="p-8 rounded-[2rem] bg-zinc-900/40 border border-white/5 backdrop-blur-xl shadow-xl flex flex-col sm:flex-row gap-6 hover:bg-zinc-900/60 transition-colors"
            >
              <div
                class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0 border border-gold-500/20 shadow-inner"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-gold-500"
                  ><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path
                    d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"
                  ></path></svg
                >
              </div>
              <div>
                <h2 class="text-xl font-semibold text-white mb-3">
                  Experiencia Contrastada
                </h2>
                <p class="text-zinc-400 text-sm leading-relaxed">
                  Con años de experiencia recorriendo el sur de España, he
                  consolidado un estilo propio y seguro. Actúo desde en bodas
                  exclusivas, donde la elegancia es clave, hasta en festivales
                  masivos que requieren un gran impacto sonoro.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Galería / Instagram Embeds -->
    <RecentMoments />

    <!-- Marcas de Fiestas -->
    <PartyBrands />
  </main>

  <Footer />
</Layout>
