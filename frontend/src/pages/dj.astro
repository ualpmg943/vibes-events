                      class="text-zinc-500 text-xs hover:text-gold-400 transition-colors tracking-wider"
                      >+34 618 64 50 43</a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Información -->
          <div class="lg:col-span-7 flex flex-col gap-6">
            <div
              class="p-8 rounded-[2rem] bg-zinc-900/40 border border-white/5 backdrop-blur-xl shadow-xl flex flex-col sm:flex-row gap-6 hover:bg-zinc-900/60 transition-colors"
            >
              <div
                class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0 border border-gold-500/20 shadow-inner"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-gold-500"
                  ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
                  ></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path
                    d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg
                >
              </div>
              <div>
                <h2 class="text-xl font-semibold text-white mb-3">
                  Versatilidad Musical
                </h2>
                <p class="text-zinc-400 text-sm leading-relaxed">
                  Especializado en música comercial, reguetón, música urbana y
                  electrónica. Adapto mi set a la pista de baile en tiempo real,
                  observando al público para asegurar que la energía no baje y
                  nadie se quede sentado.
                </p>
              </div>
            </div>

            <div
              class="p-8 rounded-[2rem] bg-zinc-900/40 border border-white/5 backdrop-blur-xl shadow-xl flex flex-col sm:flex-row gap-6 hover:bg-zinc-900/60 transition-colors"
            >
              <div
                class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0 border border-gold-500/20 shadow-inner"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-gold-500"
                  ><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path
                    d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"
                  ></path></svg
                >
              </div>
              <div>
                <h2 class="text-xl font-semibold text-white mb-3">
                  Experiencia Contrastada
                </h2>
                <p class="text-zinc-400 text-sm leading-relaxed">
                  Con años de experiencia recorriendo el sur de España, he
                  consolidado un estilo propio y seguro. Actúo desde en bodas
                  exclusivas, donde la elegancia es clave, hasta en festivales
                  masivos que requieren un gran impacto sonoro.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
