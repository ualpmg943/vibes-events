---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PackList from "../components/booking/PackList.astro";
import BookingFlow from "../components/booking/BookingFlow.astro";
---

<Layout
  title="Reservas"
  description="Reserva tu fecha con VIBE EVENTS para tu próximo evento."
>
  <Header />

  <main class="min-h-screen pt-20 pb-24 relative">
    <!-- Glow de fondo -->
    <div class="pointer-events-none fixed inset-0 z-0">
      <div class="absolute top-0 left-0 w-[700px] h-[700px] rounded-full bg-gold-500/8 blur-[200px]"></div>
    </div>

    <!-- Hero -->
    <div class="relative z-10 text-center pt-16 pb-14 px-6">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-500/10 border border-gold-500/20 text-gold-500 text-[10px] font-bold uppercase tracking-[0.2em] mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse"></span>
        Calendario
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-none mb-5">
        Reserva <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 via-gold-500 to-gold-600">tu fecha</span>
      </h1>
      <p class="text-zinc-400 text-base md:text-lg max-w-lg mx-auto">
        Selecciona el día de tu evento en nuestro calendario para comprobar disponibilidad y bloquear la fecha.
      </p>
    </div>

    <!-- Componentes de Reserva -->
    <div class="relative z-10 px-6">
      <!-- 1. Vista de Packs (por defecto visible) -->
      <PackList />

      <!-- 2. Vista de Pasarela/Flujo (visible al elegir pack) -->
      <BookingFlow />
    </div>
  </main>

  <Footer />
</Layout>
