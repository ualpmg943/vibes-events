# ─────────────────────────────────────────
#  VIBES EVENTS — Variables de Entorno
#  Copia este archivo a .env y ajusta los valores
# ─────────────────────────────────────────

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibes_events
DB_USERNAME=vibes_user
DB_PASSWORD=vibes_pass

# JWT
JWT_SECRET=your-secret-key-min-256-bits
JWT_EXPIRATION_MS=86400000

# Admin inicial
ADMIN_EMAIL=admin@vibeevents.com
ADMIN_PASSWORD=admin123

# Frontend
PUBLIC_API_URL=http://localhost:8080/api
PUBLIC_FORMSPREE_ID=your-formspree-id
